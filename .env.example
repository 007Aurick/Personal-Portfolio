# =============================================================================
# Spotify — browser (PKCE) OR public portfolio feed (Vercel serverless)
# =============================================================================

# Required for “Connect Spotify” in the browser (local dev & optional prod).
REACT_APP_SPOTIFY_CLIENT_ID=

# Optional — must exactly match a Redirect URI in the Spotify app settings.
# Spotify does NOT allow http://localhost — use 127.0.0.1 for local dev:
# REACT_APP_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback
#
# Production example:
# REACT_APP_SPOTIFY_REDIRECT_URI=https://www.aurickanwar.com/callback
#
# Scopes: user-read-currently-playing, user-read-recently-played, user-top-read
# Development mode: add your Spotify email under “Users and access” in the dashboard.

# -----------------------------------------------------------------------------
# Public feed (deployed site shows YOUR Spotify to all visitors, no “Connect”)
# -----------------------------------------------------------------------------
# Set to true on Vercel (Environment Variables for Production).
# REACT_APP_SPOTIFY_PUBLIC_FEED=true
#
# Same-origin API (Vercel): leave REACT_APP_SPOTIFY_API_BASE unset — /api/spotify is on your domain.
#
# --- Local dev (npm start, recommended) ---
# package.json has "proxy" → your production origin. The browser calls /api/spotify on :3000; CRA forwards it.
# REACT_APP_SPOTIFY_PUBLIC_FEED=true
# Do NOT set REACT_APP_SPOTIFY_API_BASE (empty = same origin = proxy, no CORS issues).
#
# --- Local dev (alternative): call production URL directly ---
# Requires the deployed api/spotify.js CORS allowlist (or you will see "Failed to fetch").
# REACT_APP_SPOTIFY_PUBLIC_FEED=true
# REACT_APP_SPOTIFY_API_BASE=https://www.aurickanwar.com
#
# --- Vercel server env (Settings → Environment Variables) — NOT prefixed REACT_ ---
# SPOTIFY_CLIENT_ID=           same as Spotify Client ID (or rely on REACT_APP_SPOTIFY_CLIENT_ID below — api/spotify accepts either)
# SPOTIFY_REFRESH_TOKEN=       long-lived refresh token (required — see below)
# SPOTIFY_CLIENT_SECRET=      optional; only if your app type requires it for refresh
# SPOTIFY_CORS_ORIGINS=       optional; e.g. http://127.0.0.1:5173 if you use another dev port (comma-separated)
#
# How to get SPOTIFY_REFRESH_TOKEN (one time):
# 1. Locally: set REACT_APP_SPOTIFY_CLIENT_ID, run npm start, click Connect Spotify, finish OAuth.
# 2. DevTools → Application → Session Storage → your origin → copy value of key `spotify_refresh_token`.
# 3. Paste into Vercel as SPOTIFY_REFRESH_TOKEN (mark Sensitive). Redeploy.
#
# If Spotify ever returns a new refresh token in server logs, update the env value.
